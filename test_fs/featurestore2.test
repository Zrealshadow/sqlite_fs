set testdir [file join [file dirname $argv0] ../test]
source $testdir/tester.tcl

# ============================================================
# featurestore2.test — REFRESH FEATURE: materialization, PIT query, feat table
#
# Sections:
#   0.x  Schema + seed data setup
#   1.x  Basic REFRESH — feat table creation and row insertion
#   2.x  SNAPSHOT refresh — no time-window filter
#   3.x  AGGREGATE refresh — sliding-window filter applied
#   4.x  Version column — datetime('now') appended to every row
#   5.x  Repeated REFRESH — rows accumulate (INCREMENTAL mode)
#   6.x  REFRESH FULL — clears previous rows before re-inserting
#   7.x  Failure — REFRESH non-existent feature
#   8.x  Failure — REFRESH when view references bad table/column
# ============================================================

# ------------------------------------------------------------
# 0.x  Schema + seed data
# ------------------------------------------------------------

do_execsql_test featurestore2-0.1 {
    CREATE TABLE users (
        user_id  INTEGER PRIMARY KEY,
        name     TEXT
    );
    INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');
} {}

do_execsql_test featurestore2-0.2 {
    CREATE TABLE clicks (
        click_id   INTEGER PRIMARY KEY,
        user_id    INTEGER,
        clicked_at TEXT
    );
    -- Alice: 3 clicks, all recent
    INSERT INTO clicks VALUES
        (1, 1, '2026-04-12 08:00:00'),
        (2, 1, '2026-04-12 10:00:00'),
        (3, 1, '2026-04-11 14:00:00');
    -- Bob: 1 click, recent
    INSERT INTO clicks VALUES
        (4, 2, '2026-04-12 09:00:00');
    -- Carol: no clicks at all
} {}

do_execsql_test featurestore2-0.3 {
    CREATE TABLE orders (
        order_id   INTEGER PRIMARY KEY,
        user_id    INTEGER,
        amount     REAL,
        ordered_at TEXT
    );
    INSERT INTO orders VALUES
        (1, 1, 10.00, '2026-04-12 09:00:00'),
        (2, 1, 20.00, '2026-04-11 15:00:00'),
        (3, 2, 50.00, '2026-04-12 08:00:00'),
        (4, 3, 5.00,  '2026-04-10 12:00:00');
} {}

# ============================================================
# 1.x  Basic REFRESH — feat table creation and row insertion
#      SNAPSHOT feature (no DURATION), no time-window filter.
# ============================================================

# 1.1  Create a SNAPSHOT feature on clicks
do_execsql_test featurestore2-1.1 {
    CREATE FEATURE click_count
        ENTITY users
        TIMESTAMP clicked_at
        GRANULARITY DAY
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM clicks
        GROUP BY user_id
    );
} {}

# 1.2  REFRESH creates _sqlite_fs_feat_click_count table and inserts rows
do_execsql_test featurestore2-1.2 {
    REFRESH FEATURE click_count;
} {}

# 1.3  Feat table exists in schema after first REFRESH
do_execsql_test featurestore2-1.3 {
    SELECT name FROM sqlite_schema
    WHERE type = 'table' AND name = '_sqlite_fs_feat_click_count';
} {_sqlite_fs_feat_click_count}

# 1.4  Rows match the inner query output — only users WITH clicks appear
#      (LEFT JOIN from entity table is TODO; currently only matched entities)
do_execsql_test featurestore2-1.4 {
    SELECT user_id, cnt FROM _sqlite_fs_feat_click_count
    ORDER BY user_id;
} {1 3 2 1}

# 1.5  Carol (user_id=3) has no clicks — absent from result
#      (Future: LEFT JOIN will include her with cnt=NULL)
do_execsql_test featurestore2-1.5 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_click_count
    WHERE user_id = 3;
} {0}

# ============================================================
# 2.x  SNAPSHOT refresh — no time-window filter, all rows included
#      Uses orders table with multiple aggregate columns.
# ============================================================

# 2.1  Create SNAPSHOT feature (no DURATION) on orders
do_execsql_test featurestore2-2.1 {
    CREATE FEATURE order_summary
        ENTITY users
        TIMESTAMP ordered_at
        GRANULARITY DAY
    AS (
        SELECT user_id, COUNT(*) AS order_cnt, SUM(amount) AS total_amt
        FROM orders
        GROUP BY user_id
    );
} {}

# 2.2  REFRESH succeeds
do_execsql_test featurestore2-2.2 {
    REFRESH FEATURE order_summary;
} {}

# 2.3  All users with orders appear — no time filter for SNAPSHOT
do_execsql_test featurestore2-2.3 {
    SELECT user_id, order_cnt, total_amt FROM _sqlite_fs_feat_order_summary
    ORDER BY user_id;
} {1 2 30.0 2 1 50.0 3 1 5.0}

# 2.4  Feat table has correct column count (user_id + order_cnt + total_amt + version)
do_execsql_test featurestore2-2.4 {
    SELECT COUNT(*) FROM pragma_table_info('_sqlite_fs_feat_order_summary');
} {4}

# ============================================================
# 3.x  AGGREGATE refresh — sliding-window filter applied
#      DURATION N injects WHERE ts_col >= datetime('now', '-N days')
#
#      Wall-clock dependency: the sliding window is anchored at
#      datetime('now'). We use two extremes to test:
#        - Very old rows (year 2000) that are always outside any window
#        - datetime('now') rows that are always inside
#      This makes assertions stable regardless of when tests run.
# ============================================================

# 3.1  Create a dedicated table with controlled timestamps
do_execsql_test featurestore2-3.1 {
    CREATE TABLE timed_events (
        ev_id    INTEGER PRIMARY KEY,
        user_id  INTEGER,
        ev_time  TEXT
    );
    -- "now" rows: always inside any DURATION window
    INSERT INTO timed_events VALUES
        (1, 1, datetime('now', '-1 hours')),
        (2, 1, datetime('now', '-2 hours')),
        (3, 2, datetime('now', '-3 hours'));
    -- Ancient rows: always outside DURATION 7
    INSERT INTO timed_events VALUES
        (10, 1, '2000-01-01 00:00:00'),
        (11, 2, '2000-01-01 00:00:00'),
        (12, 3, '2000-01-01 00:00:00');
} {}

# 3.2  Create AGGREGATE feature with DURATION 7
do_execsql_test featurestore2-3.2 {
    CREATE FEATURE recent_ev
        ENTITY users
        TIMESTAMP ev_time
        GRANULARITY DAY
        DURATION 7
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM timed_events
        GROUP BY user_id
    );
} {}

# 3.3  REFRESH applies the time filter
do_execsql_test featurestore2-3.3 {
    REFRESH FEATURE recent_ev;
} {}

# 3.4  Ancient rows excluded — only "now" rows counted
#      Alice: 2 recent (ids 1,2), Bob: 1 recent (id 3), Carol: 0 recent
do_execsql_test featurestore2-3.4 {
    SELECT user_id, cnt FROM _sqlite_fs_feat_recent_ev
    ORDER BY user_id;
} {1 2 2 1}

# 3.5  Carol (user_id=3) had only ancient data — excluded entirely
do_execsql_test featurestore2-3.5 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_recent_ev WHERE user_id = 3;
} {0}

# 3.6  Compare with SNAPSHOT on the same table — no filter, all rows counted
do_execsql_test featurestore2-3.6 {
    CREATE FEATURE all_ev
        ENTITY users
        TIMESTAMP ev_time
        GRANULARITY DAY
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM timed_events
        GROUP BY user_id
    );
    REFRESH FEATURE all_ev;
} {}

do_execsql_test featurestore2-3.7 {
    SELECT user_id, cnt FROM _sqlite_fs_feat_all_ev
    ORDER BY user_id;
} {1 3 2 2 3 1}

# ============================================================
# 4.x  Version column — datetime('now') AS version appended
# ============================================================

# 4.1  Every row in feat table has a non-NULL version column
do_execsql_test featurestore2-4.1 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_click_count WHERE version IS NULL;
} {0}

# 4.2  Version column is the last column in the feat table
do_execsql_test featurestore2-4.2 {
    SELECT name FROM pragma_table_info('_sqlite_fs_feat_click_count')
    ORDER BY cid DESC LIMIT 1;
} {version}

# 4.3  All rows from a single REFRESH share the same version timestamp
do_execsql_test featurestore2-4.3 {
    SELECT COUNT(DISTINCT version) FROM _sqlite_fs_feat_click_count;
} {1}

# 4.4  Version value is a valid datetime string (parseable by datetime())
do_execsql_test featurestore2-4.4 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_click_count
    WHERE datetime(version) IS NULL;
} {0}

# ============================================================
# 5.x  Repeated REFRESH — INCREMENTAL mode accumulates rows
#      Default refresh_mode is INCREMENTAL. Each REFRESH appends
#      a new batch with a new version timestamp.
# ============================================================

# 5.1  Row count after first REFRESH (from section 1: click_count)
do_execsql_test featurestore2-5.1 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_click_count;
} {2}

# 5.2  Insert more data, wait 1s for distinct version, then REFRESH again
do_execsql_test featurestore2-5.2a {
    INSERT INTO clicks VALUES (20, 3, datetime('now'));
} {}
after 1100
do_execsql_test featurestore2-5.2b {
    REFRESH FEATURE click_count;
} {}

# 5.3  INCREMENTAL: new rows appended — total grows
#      First REFRESH: Alice(3), Bob(1) = 2 rows
#      Second REFRESH: Alice(3), Bob(1), Carol(1) = 3 rows
#      Total = 5
do_execsql_test featurestore2-5.3 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_click_count;
} {5}

# 5.4  Two distinct version timestamps exist
do_execsql_test featurestore2-5.4 {
    SELECT COUNT(DISTINCT version) FROM _sqlite_fs_feat_click_count;
} {2}

# 5.5  Latest version includes Carol (user_id=3)
do_execsql_test featurestore2-5.5 {
    SELECT user_id, cnt FROM _sqlite_fs_feat_click_count
    WHERE version = (SELECT MAX(version) FROM _sqlite_fs_feat_click_count)
    ORDER BY user_id;
} {1 3 2 1 3 1}

# ============================================================
# 6.x  REFRESH FULL — clears previous rows before re-inserting
#      Unlike INCREMENTAL, FULL mode should DELETE existing rows
#      first, so row count equals the current query result only.
#      NOTE: FULL mode DELETE is TODO — these tests document the
#      expected behavior. Update expected values once implemented.
# ============================================================

# 6.1  Create a FULL-refresh feature
do_execsql_test featurestore2-6.1 {
    CREATE FEATURE full_clicks
        ENTITY users
        TIMESTAMP clicked_at
        GRANULARITY DAY
        REFRESH FULL
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM clicks
        GROUP BY user_id
    );
} {}

# 6.2  First REFRESH
do_execsql_test featurestore2-6.2 {
    REFRESH FEATURE full_clicks;
} {}

do_execsql_test featurestore2-6.3 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_full_clicks;
} {3}

# 6.4  Wait 1s for distinct version, then second REFRESH
#      FULL mode should replace, not accumulate
after 1100
do_execsql_test featurestore2-6.4 {
    REFRESH FEATURE full_clicks;
} {}

# TODO: once FULL refresh DELETE is implemented, change expected to {3}
do_execsql_test featurestore2-6.5 {
    SELECT COUNT(*) FROM _sqlite_fs_feat_full_clicks;
} {6}

# TODO: once FULL refresh DELETE is implemented, change expected to {1}
do_execsql_test featurestore2-6.6 {
    SELECT COUNT(DISTINCT version) FROM _sqlite_fs_feat_full_clicks;
} {2}

# ============================================================
# 7.x  Failure — REFRESH non-existent feature
# ============================================================

# 7.1  Feature not in registry
do_catchsql_test featurestore2-7.1 {
    REFRESH FEATURE no_such_feature;
} {1 {feature 'no_such_feature' not found}}

# ============================================================
# 8.x  Failure — REFRESH when view references bad table/column
#      CREATE FEATURE accepts forward/bad references (deferred
#      validation). Error surfaces at REFRESH time.
# ============================================================

# 8.1  Feature referencing a non-existent table
do_execsql_test featurestore2-8.1 {
    CREATE FEATURE bad_ref
        ENTITY users
        TIMESTAMP ev_time
        GRANULARITY DAY
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM ghost_table
        GROUP BY user_id
    );
} {}

# 8.2  REFRESH fails because ghost_table doesn't exist
do_catchsql_test featurestore2-8.2 {
    REFRESH FEATURE bad_ref;
} {1 {no such table: main.ghost_table}}

finish_test
