set testdir [file join [file dirname $argv0] ../test]
source $testdir/tester.tcl

# ============================================================
# featurestore1.test — CREATE FEATURE: syntax, validation, defaults
#
# Syntax under test:
#   CREATE FEATURE <name>
#     ENTITY      <table>
#     TIMESTAMP   <col>
#     GRANULARITY HOUR | DAY
#     [ DURATION  <n> ]
#     [ REFRESH   FULL | INCREMENTAL ]
#     [ RETAIN    <n> ]
#   AS ( <select> );
#
# Design notes (current phase):
#   - Granularity validated at CREATE time (HOUR | DAY only).
#   - Timestamp column existence NOT validated at CREATE time
#     (deferred to REFRESH).
#   - Query table/column existence NOT validated at CREATE time;
#     CREATE VIEW accepts forward references — caught at query time.
#   - SQL syntax errors inside AS (...) ARE caught (via CREATE VIEW).
#   - Duplicate feature names rejected by PRIMARY KEY constraint.
#   - _sqlite_fs_features columns: feature_name, entity_table,
#     timestamp_column, col_gran, gran_expr, window_size,
#     feature_type, refresh_mode, retention_count, created_at,
#     last_refreshed.
#   - Removed columns: query_definition, source_tables,
#     feat_col_names, feat_col_types.
#   - Each successful CREATE FEATURE also creates:
#     CREATE VIEW _sqlite_fs_view_<name> AS <query>
#
# Sections:
#   0.x  Schema setup
#   1.x  Success — required clauses only (SNAPSHOT defaults)
#   2.x  Success — AGGREGATE (DURATION) + optional clauses
#   3.x  Success — granularity variants and gran_expr derivation
#   4.x  Failure — invalid granularity (HOUR|DAY only)
#   5.x  Success — timestamp not validated at CREATE time
#   6.x  Failure — SQL syntax error inside AS (...)
#   7.x  Failure — missing required clauses (parser-level)
#   8.x  Corner cases
#   9.x  Final registry state
# ============================================================

# ------------------------------------------------------------
# 0.x  Schema setup — reused by all tests
# ------------------------------------------------------------

do_execsql_test featurestore1-0.1 {
    CREATE TABLE users (
        user_id  INTEGER PRIMARY KEY,
        name     TEXT
    );
} {}

do_execsql_test featurestore1-0.2 {
    CREATE TABLE events (
        event_id   INTEGER PRIMARY KEY,
        user_id    INTEGER,
        action     TEXT,
        event_time TEXT
    );
} {}

# ============================================================
# 1.x  Success — required clauses only, verify defaults
# ============================================================

# 1.1  Minimal valid CREATE FEATURE — no optional clauses
do_execsql_test featurestore1-1.1 {
    CREATE FEATURE snap_basic
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

# 1.2  Verify stored profile: feature_type=SNAPSHOT, INCREMENTAL default,
#      NULL window_size and retention_count
do_execsql_test featurestore1-1.2 {
    SELECT feature_name, entity_table, timestamp_column, col_gran,
           feature_type, window_size, refresh_mode, retention_count
    FROM _sqlite_fs_features
    WHERE feature_name = 'snap_basic';
} {snap_basic users event_time DAY SNAPSHOT {} INCREMENTAL {}}

# 1.3  gran_expr derived from timestamp_col + DAY granularity
do_execsql_test featurestore1-1.3 {
    SELECT gran_expr FROM _sqlite_fs_features
    WHERE feature_name = 'snap_basic';
} {DATE(event_time)}

# 1.4  CREATE FEATURE also creates _sqlite_fs_view_<name> atomically
do_execsql_test featurestore1-1.4 {
    SELECT name FROM sqlite_schema
    WHERE type = 'view' AND name = '_sqlite_fs_view_snap_basic';
} {_sqlite_fs_view_snap_basic}

# ============================================================
# 2.x  Success — AGGREGATE (DURATION present) + optional clauses
# ============================================================

# 2.1  DURATION n → feature_type=AGGREGATE, window_size=n
do_execsql_test featurestore1-2.1 {
    CREATE FEATURE agg_7day
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 7
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.2 {
    SELECT feature_type, window_size FROM _sqlite_fs_features
    WHERE feature_name = 'agg_7day';
} {AGGREGATE 7}

# 2.3  DURATION 1 — minimum window, still AGGREGATE
do_execsql_test featurestore1-2.3 {
    CREATE FEATURE agg_1day
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 1
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.4 {
    SELECT feature_type, window_size FROM _sqlite_fs_features
    WHERE feature_name = 'agg_1day';
} {AGGREGATE 1}

# 2.5  REFRESH FULL overrides INCREMENTAL default
do_execsql_test featurestore1-2.5 {
    CREATE FEATURE agg_full_refresh
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 3
        REFRESH FULL
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.6 {
    SELECT refresh_mode FROM _sqlite_fs_features
    WHERE feature_name = 'agg_full_refresh';
} {FULL}

# 2.7  REFRESH INCREMENTAL explicit (same as default)
do_execsql_test featurestore1-2.7 {
    CREATE FEATURE agg_incr_explicit
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 3
        REFRESH INCREMENTAL
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.8 {
    SELECT refresh_mode FROM _sqlite_fs_features
    WHERE feature_name = 'agg_incr_explicit';
} {INCREMENTAL}

# 2.9  RETAIN n stores retention_count
do_execsql_test featurestore1-2.9 {
    CREATE FEATURE agg_with_retain
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 7
        RETAIN 30
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.10 {
    SELECT retention_count FROM _sqlite_fs_features
    WHERE feature_name = 'agg_with_retain';
} {30}

# 2.11  All optional clauses — full profile round-trip
do_execsql_test featurestore1-2.11 {
    CREATE FEATURE agg_all_opts
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
        DURATION 14
        REFRESH FULL
        RETAIN 4
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-2.12 {
    SELECT feature_type, window_size, refresh_mode, retention_count
    FROM _sqlite_fs_features
    WHERE feature_name = 'agg_all_opts';
} {AGGREGATE 14 FULL 4}

# ============================================================
# 3.x  Granularity variants and gran_expr derivation
# ============================================================

# 3.1  GRANULARITY HOUR accepted
do_execsql_test featurestore1-3.1 {
    CREATE FEATURE hourly_feat
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY HOUR
        DURATION 24
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events
        GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-3.2 {
    SELECT col_gran FROM _sqlite_fs_features
    WHERE feature_name = 'hourly_feat';
} {HOUR}

# 3.3  gran_expr for HOUR uses strftime
do_execsql_test featurestore1-3.3 {
    SELECT gran_expr FROM _sqlite_fs_features
    WHERE feature_name = 'hourly_feat';
} {{strftime('%Y-%m-%dT%H', event_time)}}

# 3.4  Each successful CREATE FEATURE creates a corresponding view
do_execsql_test featurestore1-3.4 {
    SELECT name FROM sqlite_schema
    WHERE type = 'view'
      AND name IN ('_sqlite_fs_view_hourly_feat', '_sqlite_fs_view_agg_7day')
    ORDER BY name;
} {_sqlite_fs_view_agg_7day _sqlite_fs_view_hourly_feat}

# ============================================================
# 4.x  Failure — invalid granularity (only HOUR | DAY accepted)
# ============================================================

do_catchsql_test featurestore1-4.1 {
    CREATE FEATURE bad_gran_week
        ENTITY users TIMESTAMP event_time GRANULARITY WEEK
    AS (SELECT user_id, event_time FROM events);
} {1 {granularity must be HOUR or DAY (use WINDOW + DAY for week/month/year)}}

do_catchsql_test featurestore1-4.2 {
    CREATE FEATURE bad_gran_month
        ENTITY users TIMESTAMP event_time GRANULARITY MONTH
    AS (SELECT user_id, event_time FROM events);
} {1 {granularity must be HOUR or DAY (use WINDOW + DAY for week/month/year)}}

do_catchsql_test featurestore1-4.3 {
    CREATE FEATURE bad_gran_year
        ENTITY users TIMESTAMP event_time GRANULARITY YEAR
    AS (SELECT user_id, event_time FROM events);
} {1 {granularity must be HOUR or DAY (use WINDOW + DAY for week/month/year)}}

do_catchsql_test featurestore1-4.4 {
    CREATE FEATURE bad_gran_minute
        ENTITY users TIMESTAMP event_time GRANULARITY MINUTE
    AS (SELECT user_id, event_time FROM events);
} {1 {granularity must be HOUR or DAY (use WINDOW + DAY for week/month/year)}}

# 4.5  Failed granularity attempts leave no row and no view
do_execsql_test featurestore1-4.5 {
    SELECT COUNT(*) FROM _sqlite_fs_features
    WHERE feature_name IN ('bad_gran_week','bad_gran_month',
                           'bad_gran_year','bad_gran_minute');
} {0}

do_execsql_test featurestore1-4.6 {
    SELECT COUNT(*) FROM sqlite_schema
    WHERE type = 'view'
      AND name IN ('_sqlite_fs_view_bad_gran_week','_sqlite_fs_view_bad_gran_month',
                   '_sqlite_fs_view_bad_gran_year','_sqlite_fs_view_bad_gran_minute');
} {0}

# ============================================================
# 5.x  Timestamp column NOT validated at CREATE time
#       Validation is deferred to REFRESH.
# ============================================================

# 5.1  TIMESTAMP names a column absent from SELECT output — still accepted
do_execsql_test featurestore1-5.1 {
    CREATE FEATURE ts_absent
        ENTITY users
        TIMESTAMP no_such_col
        GRANULARITY DAY
    AS (
        SELECT user_id, event_time FROM events
    );
} {}

do_execsql_test featurestore1-5.2 {
    SELECT timestamp_column FROM _sqlite_fs_features
    WHERE feature_name = 'ts_absent';
} {no_such_col}

# 5.3  TIMESTAMP column appears only in WHERE — accepted at CREATE time
do_execsql_test featurestore1-5.3 {
    CREATE FEATURE ts_where_only
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
    AS (
        SELECT user_id, COUNT(*) AS cnt
        FROM events
        WHERE event_time > '2026-01-01'
        GROUP BY user_id
    );
} {}

# ============================================================
# 6.x  Failure — SQL syntax error inside AS (...) caught by CREATE VIEW
# ============================================================

# 6.1  Bad table/column references are NOT caught at CREATE time;
#      SQLite defers view reference validation to query time
do_execsql_test featurestore1-6.1 {
    CREATE FEATURE bad_table_ref
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
    AS (
        SELECT user_id, event_time FROM no_such_table
    );
} {}

# 6.2  SQL syntax error inside AS (...) — caught during CREATE VIEW parsing
do_catchsql_test featurestore1-6.2 {
    CREATE FEATURE bad_syntax
        ENTITY users
        TIMESTAMP event_time
        GRANULARITY DAY
    AS (
        SELECT FROM events
    );
} {1 {near "FROM": syntax error}}

# 6.3  Syntax error rolls back atomically: no metadata row, no view
do_execsql_test featurestore1-6.3 {
    SELECT COUNT(*) FROM _sqlite_fs_features
    WHERE feature_name = 'bad_syntax';
} {0}

do_execsql_test featurestore1-6.4 {
    SELECT COUNT(*) FROM sqlite_schema
    WHERE type = 'view' AND name = '_sqlite_fs_view_bad_syntax';
} {0}

# ============================================================
# 7.x  Failure — missing required clauses (parser-level errors)
# ============================================================

do_catchsql_test featurestore1-7.1 {
    CREATE FEATURE no_entity
        TIMESTAMP event_time GRANULARITY DAY
    AS (SELECT user_id, event_time FROM events);
} {1 {near "TIMESTAMP": syntax error}}

do_catchsql_test featurestore1-7.2 {
    CREATE FEATURE no_timestamp
        ENTITY users GRANULARITY DAY
    AS (SELECT user_id, event_time FROM events);
} {1 {near "GRANULARITY": syntax error}}

do_catchsql_test featurestore1-7.3 {
    CREATE FEATURE no_granularity
        ENTITY users TIMESTAMP event_time
    AS (SELECT user_id, event_time FROM events);
} {1 {near "AS": syntax error}}

do_catchsql_test featurestore1-7.4 {
    CREATE FEATURE no_as
        ENTITY users TIMESTAMP event_time GRANULARITY DAY;
} {1 {near ";": syntax error}}

do_catchsql_test featurestore1-7.5 {
    CREATE FEATURE no_parens
        ENTITY users TIMESTAMP event_time GRANULARITY DAY
    AS SELECT user_id, event_time FROM events;
} {1 {near "SELECT": syntax error}}

do_execsql_test featurestore1-7.6 {
    SELECT COUNT(*) FROM _sqlite_fs_features
    WHERE feature_name IN ('no_entity','no_timestamp','no_granularity',
                           'no_as','no_parens');
} {0}

# ============================================================
# 8.x  Corner cases
# ============================================================

# 8.1  Duplicate feature name — rejected by PRIMARY KEY constraint
do_catchsql_test featurestore1-8.1 {
    CREATE FEATURE snap_basic
        ENTITY users TIMESTAMP event_time GRANULARITY DAY DURATION 5 RETAIN 10
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events GROUP BY user_id, event_time
    );
} {1 {UNIQUE constraint failed: _sqlite_fs_features.feature_name}}

# 8.2  Original row is unchanged after rejected duplicate
do_execsql_test featurestore1-8.2 {
    SELECT feature_type, window_size, retention_count
    FROM _sqlite_fs_features
    WHERE feature_name = 'snap_basic';
} {SNAPSHOT {} {}}

# 8.3  RETAIN 0 is accepted
do_execsql_test featurestore1-8.3 {
    CREATE FEATURE retain_zero
        ENTITY users TIMESTAMP event_time GRANULARITY DAY DURATION 1 RETAIN 0
    AS (
        SELECT user_id, event_time, COUNT(*) AS cnt
        FROM events GROUP BY user_id, event_time
    );
} {}

do_execsql_test featurestore1-8.4 {
    SELECT retention_count FROM _sqlite_fs_features
    WHERE feature_name = 'retain_zero';
} {0}

# 8.5  GRANULARITY case-insensitive — lowercase 'day' accepted
do_execsql_test featurestore1-8.5 {
    CREATE FEATURE lower_gran
        ENTITY users TIMESTAMP event_time GRANULARITY day
    AS (SELECT user_id, event_time FROM events);
} {}

do_execsql_test featurestore1-8.6 {
    SELECT col_gran FROM _sqlite_fs_features
    WHERE feature_name = 'lower_gran';
} {day}

# ============================================================
# 9.x  Final registry state — only valid features registered
# ============================================================

# 9.1  All successfully created features are present
do_execsql_test featurestore1-9.1 {
    SELECT feature_name FROM _sqlite_fs_features ORDER BY feature_name;
} {agg_1day agg_7day agg_all_opts agg_full_refresh agg_incr_explicit
   agg_with_retain bad_table_ref hourly_feat lower_gran retain_zero
   snap_basic ts_absent ts_where_only}

# 9.2  Each registered feature has a corresponding view in sqlite_schema
do_execsql_test featurestore1-9.2 {
    SELECT COUNT(*) FROM sqlite_schema
    WHERE type = 'view' AND name LIKE '_sqlite_fs_view_%';
} {13}

finish_test
